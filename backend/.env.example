# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local dev: mongodb://127.0.0.1:27017/developer-diary
# Production (MongoDB Atlas): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/developer-diary?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/developer-diary

# JWT
# In production this MUST be a long, random, secret string (32+ characters).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server refuses to start in production with a missing/short/default value.
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Cookies
JWT_COOKIE_NAME=diary_token

# CORS — the origin(s) allowed to call this API with credentials.
# Comma-separate multiple origins if the frontend is deployed separately
# from this backend, e.g.: https://your-app.onrender.com,https://your-domain.com
CLIENT_URL=http://localhost:5000

# File uploads
MAX_UPLOAD_SIZE_MB=5

# Administrator seed (used ONLY by `npm run seed` to create the one
# admin account — there is no public registration). Change the password
# to something strong before seeding, then consider removing it from
# this file afterwards.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password
